{
	"name": "sovereign-command-center-2",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:strict": "vite dev --port 5173 --strictPort",
		"dev:reset": "node -e \"const fs=require('fs');['node_modules/.vite','.svelte-kit'].forEach((p)=>{try{fs.rmSync(p,{recursive:true,force:true});console.log('removed',p);}catch{}})\" && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:e2e": "playwright install && playwright test",
		"test:correlation": "npx vitest run --config vitest.unit.config.ts src/lib/server/correlation-rule.test.ts src/lib/server/fusion-model.test.ts",
		"test:correlation:smoke": "node scripts/smoke-correlation-trigger.mjs",
		"test": "npm run test:e2e",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"keys:generate": "node scripts/generate-sovereign-keypair.mjs",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"ledger:verify": "node scripts/verify-ledger.js",
		"ledger:chaos": "node scripts/chaos-test.mjs",
		"ledger:heal": "node scripts/heal-ledger.mjs",
		"sentinel:auto-heal": "node scripts/sentinel-auto-heal.mjs",
		"sentinel:bootstrap": "node scripts/sentinel-auto-heal.mjs --bootstrap",
		"sentinel:bootstrap:tainted": "node scripts/sentinel-auto-heal.mjs --bootstrap --allow-tainted-bootstrap",
		"replay:118": "node scripts/reality-replay-118.mjs",
		"replay:441": "node scripts/reality-replay-441.mjs",
		"replay:991": "node scripts/reality-replay-991.mjs",
		"k8s:init:defensive": "pwsh -ExecutionPolicy Bypass -File scripts/k8s-init-defensive.ps1",
		"validate:sovereign": "npm run test:correlation && npm run test:correlation:smoke && python scripts/pivot-shadow-sim.py",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"dependencies": {
		"@prisma/client": "^6.19.0",
		"https-proxy-agent": "^9.0.0",
		"ioredis": "^5.10.1",
		"node-fetch": "^3.3.2"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@libsql/client": "^0.17.2",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/addon-docs": "^10.4.0",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.0",
		"@storybook/sveltekit": "^10.4.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6",
		"better-auth": "^1.6.11",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prisma": "^6.19.0",
		"storybook": "^10.4.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.6"
	},
	"overrides": {
		"cookie": "^0.7.2",
		"@esbuild-kit/core-utils": {
			"esbuild": "^0.25.12"
		}
	}
}